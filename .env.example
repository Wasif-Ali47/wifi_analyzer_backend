# MongoDB — base URI without relying on path DB name; app uses MONGODB_DB_NAME
MONGODB_URI=mongodb://127.0.0.1:27017

# Dedicated database name (collections: promptgenerations)
MONGODB_DB_NAME=ai_prompt_generator

# Server
PORT=8000

# OpenAI (chat completion for prompt text)
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
